# Copiar a .env y rellenar valores reales (nunca commitear .env)

SECRET_KEY=cambia-esto-por-una-clave-secreta-larga
DEBUG=True

# Lista separada por comas
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=django
DB_USER=ubuntu
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# The Movie Database (https://www.themoviedb.org/settings/api)
API_KEY=
API_TOKEN=

# Opcional: ruta absoluta a CSS u otros estáticos fuera del proyecto
# EXTRA_STATIC_DIR=
